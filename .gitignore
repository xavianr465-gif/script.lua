-- // 1. Global Settings (Edit these as needed)
getgenv().autogenSettings = {
    PUZZLES_BEFORE_REJOIN = 15,
    PLAYERS_BEFORE_START = 3,
    MAXIMUM_TIMER_SECONDS = 120,
    MINIMUM_TIMER_SECONDS = 3,
    RECENT_SERVER_BLOCKLIST_LENGTH = 5,
    PLAYER_TIMER_CHECK = 1,
    SWAP_ON_MS4 = true,
    SKIP_LAST_PUZZLE = false,
    DISABLE_RENDERING = false,
    AUTO_HIDE_ABILITY = true,
    RUN_ONLY_WHEN_COOLKIDD = false,
    WEBHOOK = "", -- Add your Discord Webhook here if you want logs
}

-- // 2. Load UI Library (Rayfield)
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- // 3. Create Interface Window
local Window = Rayfield:CreateWindow({
   Name = "Autogen Interface",
   LoadingTitle = "Autogen Suite",
   LoadingSubtitle = "GitHub Edition",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "AutogenConfig",
      FileName = "MainSettings"
   },
   KeySystem = false, -- No key required
})

-- // 4. Tab Setup
local MainTab = Window:CreateTab("Main", 4483362458)

MainTab:CreateSection("Auto-Puzzle Control")

MainTab:CreateButton({
   Name = "EXECUTE AUTO-PUZZLE",
   Callback = function()
      -- THE LINK: This pulls from your repository 'script.lua' and file 'script.lua'
      local rawUrl = "https://raw.githubusercontent.com/xavianr465-gif/script.lua/main/script.lua"
      
      local success, scriptContent = pcall(function()
          return game:HttpGet(rawUrl)
      end)
      
      if success and scriptContent and not scriptContent:find("404") then
          local func, err = loadstring(scriptContent)
          if func then
              func() -- Starts the engine
              Rayfield:Notify({Title = "Success", Content = "Autogen is now running!", Duration = 5})
          else
              -- This means your file on GitHub has a Lua code error
              Rayfield:Notify({Title = "Script Error", Content = "The code on GitHub is invalid: " .. tostring(err), Duration = 10})
          end
      else
          -- This means the link is dead or the repository is PRIVATE
          Rayfield:Notify({Title = "Fetch Failed", Content = "Could not find script.lua. Make sure repo is PUBLIC.", Duration = 10})
      end
   end,
})

-- // 5. Visual Toggles
MainTab:CreateSection("Performance")

MainTab:CreateToggle({
   Name = "Disable Rendering (Low Lag)",
   CurrentValue = false,
   Flag = "RenderToggle",
   Callback = function(Value)
      getgenv().autogenSettings.DISABLE_RENDERING = Value
   end,
})

Rayfield:Notify({Title = "Interface Ready", Content = "Ready to start grinding.", Duration = 3})


